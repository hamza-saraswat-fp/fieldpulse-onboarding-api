# Salesforce → API auth. Generated with `openssl rand -hex 32`.
# Required. Salesforce presents this as `Authorization: Bearer <key>`.
SALESFORCE_INTEGRATION_KEY=

# Supabase project. The API uses the service-role key on the server side
# to bypass RLS when creating wizard_sessions rows.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public URL of the wizard UI. Used to build the onboardingLink returned
# to Salesforce. Should NOT point to this API service.
# Example: https://onboarding.fieldpulse.com
NEXT_PUBLIC_APP_URL=
